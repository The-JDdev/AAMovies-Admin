<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Type: Movie or Series -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type *"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <RadioButton
                android:id="@+id/rb_movie"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Movie"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_blue"
                android:checked="true"
                android:layout_marginEnd="24dp" />

            <RadioButton
                android:id="@+id/rb_series"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Series"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_blue" />

        </RadioGroup>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title *"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_title"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="Enter title"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Year -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Release Year *"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_year"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. 2024"
            android:inputType="number"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category *"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_category"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="14dp" />

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_language"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. Hindi, English"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Quality -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quality"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_quality"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. HD, 4K, 1080p"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Poster URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Poster Image URL"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_poster"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="https://example.com/poster.jpg"
            android:inputType="textUri"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Horizontal Banner URL (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Horizontal Banner URL"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_banner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="https://example.com/banner.jpg (wide banner for detail screen)"
            android:inputType="textUri"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Industry (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Industry"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_industry"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. Bollywood, Hollywood, Tollywood"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Rating (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rating"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_rating"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. 8.5/10 or PG-13"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Star Cast (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Star Cast"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_star_cast"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. Shah Rukh Khan, Deepika Padukone"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_description"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="Movie description..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Genre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Genre"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_movie_genre"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:hint="e.g. Action, Thriller, Romance"
            android:padding="14dp"
            android:layout_marginBottom="14dp" />

        <!-- Toggles: Trending + Pinned -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cb_trending"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🔥 Trending"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_blue" />

            <CheckBox
                android:id="@+id/cb_pinned"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📌 Pin to Top"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/accent_blue" />

        </LinearLayout>

        <!-- Screenshots section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Screenshots"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add screenshot image URLs (one per field)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/ll_screenshots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_add_screenshot"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="+ Add Screenshot URL"
            android:textColor="@color/accent_blue"
            android:background="@drawable/bg_button_outline"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Download Links section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Download Links"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/ll_download_links"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_add_download_link"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ Add Download Link"
            android:textColor="@color/accent_blue"
            android:background="@drawable/bg_button_outline"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_save_movie"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Movie"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
