<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_download_item"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Download Link"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btn_remove_link"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Remove"
            android:textColor="@color/error_red"
            android:background="@android:color/transparent"
            android:textSize="12sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/et_link_label"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_input_field"
        android:hint="Label (e.g. HD 720p)"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_link_url"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_input_field"
        android:hint="Download URL"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:inputType="textUri"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_link_size"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_input_field"
        android:hint="File size (e.g. 1.2 GB)"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:padding="12dp" />

</LinearLayout>
